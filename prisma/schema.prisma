generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Una "partida": agrupa invitados y pistas para no mezclar datos entre eventos.
model GameSession {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)

  /// Si está en true, los invitados ven el cuadro "¿Quién lo hizo?" en su
  /// vista. Lo prende/apaga el host desde la pestaña Votación.
  votingEnabled Boolean @default(false)

  /// Si está en true, a los invitados les aparece el botón para ver la
  /// revelación final. Contenido editable desde el backoffice.
  revealEnabled  Boolean @default(false)
  revealTitle    String?
  revealSubtitle String?
  revealBody     String?
  revealTagline  String?
  revealImageUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guests Guest[]
  clues  Clue[]
  alerts Alert[]
  votes  Vote[]

  @@map("game_sessions")
}

model Guest {
  id            String      @id @default(cuid())
  gameSessionId String
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)

  /// Identificador único usado en la URL personal del invitado (/g/[slug]).
  slug String @unique
  name String

  /// Rol o personaje del invitado.
  roleName String?

  /// Descripción pública del invitado/personaje.
  publicDescription String?

  /// Información secreta, visible solo para este invitado en su vista personal.
  secretInfo String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Votos que este invitado emitió (a quién acusó).
  votesAsVoter Vote[] @relation("VoterVotes")

  /// Votos que este invitado recibió (quién lo acusó).
  votesAsSuspect Vote[] @relation("SuspectVotes")

  @@index([gameSessionId])
  @@map("guests")
}

enum ClueStatus {
  HIDDEN
  RELEASED
}

model Clue {
  id            String      @id @default(cuid())
  gameSessionId String
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)

  title   String
  content String

  /// URL de una imagen opcional para la pista.
  imageUrl String?

  /// Orden sugerido de liberación.
  order Int @default(0)

  status     ClueStatus @default(HIDDEN)
  releasedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameSessionId])
  @@map("clues")
}

enum AlertStatus {
  HIDDEN
  RELEASED
}

/// Alertas del expediente (ej: "Gerard nunca llegó"), liberadas por el host
/// igual que las pistas pero mostradas como una tira aparte en el front.
model Alert {
  id            String      @id @default(cuid())
  gameSessionId String
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)

  title   String
  content String

  /// Orden sugerido de liberación.
  order Int @default(0)

  status     AlertStatus @default(HIDDEN)
  releasedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameSessionId])
  @@map("alerts")
}

/// El voto de un invitado ("sospecho de X"). Un invitado solo puede votar
/// una vez por partida (constraint única); para permitir que vuelva a
/// votar hay que borrar su voto (ver "Reset total" en el backoffice).
model Vote {
  id            String      @id @default(cuid())
  gameSessionId String
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)

  voterId String
  voter   Guest  @relation("VoterVotes", fields: [voterId], references: [id], onDelete: Cascade)

  suspectId String
  suspect   Guest  @relation("SuspectVotes", fields: [suspectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([gameSessionId, voterId])
  @@index([gameSessionId])
  @@map("votes")
}
