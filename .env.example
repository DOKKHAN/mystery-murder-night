# --- Postgres ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=pass1234
POSTGRES_DB=mystery_murder_night

# Usada por Prisma. Con docker-compose no hace falta tocarla (el servicio
# "app" arma esta URL solo, apuntando al host "db"). Si corrés la app fuera
# de Docker, cambiá "db" por "localhost".
DATABASE_URL=postgresql://admin:pass1234@db:5432/mystery_murder_night

# --- Backoffice (login único de administrador) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=pass1234

# Cadena usada para firmar la cookie de sesión del admin. Esta ya es una
# cadena aleatoria funcional (64 caracteres hex) — si querés generar otra:
# openssl rand -hex 32
SESSION_SECRET=f993e36e890cb5bb27834aaf961eb99bb0c80511f24857836bd7e57fed4a3b9b
