# --- Postgres ---
POSTGRES_USER=mmn_admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mystery_murder_night

# Usada por Prisma. Con docker-compose no hace falta tocarla (el servicio
# "app" arma esta URL solo, apuntando al host "db"). Si corrés la app fuera
# de Docker, cambiá "db" por "localhost".
DATABASE_URL=postgresql://mmn_admin:changeme@db:5432/mystery_murder_night

# --- Backoffice (login único de administrador) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# Cadena larga y aleatoria usada para firmar la cookie de sesión del admin.
# Generar una, por ejemplo: openssl rand -hex 32
SESSION_SECRET=reemplazar-por-una-cadena-larga-y-aleatoria
